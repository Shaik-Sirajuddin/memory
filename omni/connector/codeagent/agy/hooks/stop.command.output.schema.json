{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stop.command.output",
  "type": "object",
  "properties": {
    "continue": {
      "type": "boolean",
      "default": true,
      "description": "Set false to prevent stopping and continue the agent loop"
    },
    "stopReason": { "type": "string", "default": null },
    "suppressOutput": { "type": "boolean", "default": false },
    "systemMessage": { "type": "string", "default": null },
    "decision": { "enum": ["block"], "type": "string", "default": null },
    "reason": { "type": "string", "default": null }
  }
}
