    "hook_event_name": { "const": "PostToolUse", "type": "string" },
    "permission_mode": { "$ref": "#/definitions/PermissionMode" },
    "model": { "type": "string" },
    "tool_name": { "type": "string" },
    "tool_input": { "type": "object" },
    "tool_response": { "type": "string", "description": "Output returned by the tool" },
