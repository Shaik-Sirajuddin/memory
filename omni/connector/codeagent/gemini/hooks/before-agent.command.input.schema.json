{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "before-agent.command.input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "transcript_path": { "type": "string" },
    "cwd": { "type": "string" },
    "hook_event_name": { "const": "BeforeAgent", "type": "string" },
    "timestamp": { "type": "string" },
    "prompt": { "type": "string", "description": "User's text submission" }
  },
  "required": ["session_id", "transcript_path", "cwd", "hook_event_name", "timestamp", "prompt"]
}
