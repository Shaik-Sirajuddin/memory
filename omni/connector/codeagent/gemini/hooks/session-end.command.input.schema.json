{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "session-end.command.input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "transcript_path": { "type": "string" },
    "cwd": { "type": "string" },
    "hook_event_name": { "const": "SessionEnd", "type": "string" },
    "timestamp": { "type": "string" },
    "reason": {
      "enum": ["exit", "clear", "logout", "prompt_input_exit", "other"],
      "type": "string",
      "description": "Reason the session ended"
    }
  },
  "required": ["session_id", "transcript_path", "cwd", "hook_event_name", "timestamp", "reason"]
}
