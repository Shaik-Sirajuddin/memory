{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "after-tool.command.input",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "ToolResponse": {
      "type": "object",
      "properties": {
        "llmContent": { "type": "string", "description": "Tool output passed to the LLM" },
        "returnDisplay": { "type": "string", "description": "Display-formatted tool output" },
        "error": { "type": "string", "description": "Error message if the tool failed", "nullable": true }
      }
    }
  },
  "properties": {
    "session_id": { "type": "string" },
    "transcript_path": { "type": "string" },
    "cwd": { "type": "string" },
    "hook_event_name": { "const": "AfterTool", "type": "string" },
    "timestamp": { "type": "string" },
    "tool_name": { "type": "string" },
    "tool_input": { "type": "object" },
    "tool_response": { "$ref": "#/definitions/ToolResponse" },
    "mcp_context": { "type": "object", "nullable": true },
    "original_request_name": { "type": "string", "nullable": true }
  },
  "required": ["session_id", "transcript_path", "cwd", "hook_event_name", "timestamp", "tool_name", "tool_input", "tool_response"]
}
