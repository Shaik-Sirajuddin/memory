{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "after-agent.command.input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "transcript_path": { "type": "string" },
    "cwd": { "type": "string" },
    "hook_event_name": { "const": "AfterAgent", "type": "string" },
    "timestamp": { "type": "string" },
    "prompt": { "type": "string", "description": "Original user request" },
    "prompt_response": { "type": "string", "description": "Final agent-generated text response" },
    "stop_hook_active": { "type": "boolean", "description": "True if this is part of a retry sequence" }
  },
  "required": ["session_id", "transcript_path", "cwd", "hook_event_name", "timestamp", "prompt", "prompt_response", "stop_hook_active"]
}
