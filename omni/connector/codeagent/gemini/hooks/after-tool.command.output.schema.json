{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "after-tool.command.output",
  "type": "object",
  "properties": {
    "continue": { "type": "boolean", "default": true },
    "stopReason": { "type": "string", "default": null },
    "suppressOutput": { "type": "boolean", "default": false },
    "systemMessage": { "type": "string", "default": null },
    "decision": { "enum": ["allow", "deny", "block"], "type": "string", "default": null },
    "reason": { "type": "string", "default": null },
    "hookSpecificOutput": {
      "type": "object",
      "properties": {
        "additionalContext": { "type": "string", "description": "Appended to the tool result" },
        "tailToolCallRequest": {
          "type": "object",
          "description": "Programmatic tool routing — triggers another tool call"
        }
      }
    }
  }
}
