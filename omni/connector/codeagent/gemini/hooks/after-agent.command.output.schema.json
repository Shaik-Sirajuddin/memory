{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "after-agent.command.output",
  "type": "object",
  "properties": {
    "continue": { "type": "boolean", "default": true },
    "stopReason": { "type": "string", "default": null },
    "suppressOutput": { "type": "boolean", "default": false },
    "systemMessage": { "type": "string", "default": null },
    "decision": {
      "enum": ["deny"],
      "type": "string",
      "default": null,
      "description": "Set to 'deny' to trigger a retry; the 'reason' field becomes the correction prompt"
    },
    "reason": { "type": "string", "default": null }
  }
}
