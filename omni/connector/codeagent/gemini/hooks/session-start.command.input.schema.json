{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "session-start.command.input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "transcript_path": { "type": "string" },
    "cwd": { "type": "string" },
    "hook_event_name": { "const": "SessionStart", "type": "string" },
    "timestamp": { "type": "string" },
    "source": {
      "enum": ["startup", "resume", "clear"],
      "type": "string",
      "description": "Reason the session started"
    }
  },
  "required": ["session_id", "transcript_path", "cwd", "hook_event_name", "timestamp", "source"]
}
