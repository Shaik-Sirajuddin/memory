{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "gemini-cli-hooks-config",
  "description": "Schema for hooks section in Gemini CLI settings.json. Config path: settings.json (hooks object)",
  "type": "object",
  "properties": {
    "hooks": {
      "type": "object",
      "description": "Map of hook event names to arrays of hook matchers",
      "properties": {
        "BeforeTool": { "$ref": "#/definitions/HookMatcherList" },
        "AfterTool": { "$ref": "#/definitions/HookMatcherList" },
        "BeforeAgent": { "$ref": "#/definitions/HookMatcherList" },
        "AfterAgent": { "$ref": "#/definitions/HookMatcherList" },
        "BeforeModel": { "$ref": "#/definitions/HookMatcherList" },
        "BeforeToolSelection": { "$ref": "#/definitions/HookMatcherList" },
        "AfterModel": { "$ref": "#/definitions/HookMatcherList" },
        "SessionStart": { "$ref": "#/definitions/HookMatcherList" },
        "SessionEnd": { "$ref": "#/definitions/HookMatcherList" },
        "Notification": { "$ref": "#/definitions/HookMatcherList" },
        "PreCompress": { "$ref": "#/definitions/HookMatcherList" }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "HookMatcherList": {
      "type": "array",
      "items": { "$ref": "#/definitions/HookMatcher" }
    },
    "HookMatcher": {
      "type": "object",
      "properties": {
        "matcher": {
          "type": "string",
          "description": "Regex pattern to match tool name or other event-specific field"
        },
        "sequential": {
          "type": "boolean",
          "description": "Run hooks sequentially instead of in parallel"
        },
        "hooks": {
          "type": "array",
          "items": { "$ref": "#/definitions/HookDefinition" }
        }
      },
      "required": ["hooks"]
    },
    "HookDefinition": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["command", "http"],
          "type": "string"
        },
        "command": {
          "type": "string",
          "description": "Shell command to execute (type=command)"
        },
        "url": {
          "type": "string",
          "description": "HTTP endpoint URL (type=http)"
        },
        "timeout": {
          "type": "integer",
          "description": "Timeout in seconds"
        }
      },
      "required": ["type"]
    }
  }
}
