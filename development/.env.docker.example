# Copy to .env.docker and fill in your keys — never commit .env.docker

# API keys / OAuth tokens (required for each agent you want to use — set one per provider)

# Claude — API key (paid API) OR OAuth token (Pro/Max subscription via `claude setup-token`)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=           # Pro/Max subscription token

# Codex — API key OR OAuth token (ChatGPT Plus subscription)
OPENAI_API_KEY=sk-...
# OPENAI_OAUTH_TOKEN=                # subscription OAuth token

# Gemini — API key OR OAuth token (Google One AI Premium)
GEMINI_API_KEY=AIza...
# GEMINI_CODE_OAUTH_TOKEN=           # subscription OAuth token

# Default models (optional — omit to use each CLI's built-in default)
ANTHROPIC_MODEL=claude-sonnet-4-6
CODEX_MODEL=codex-mini-latest
GEMINI_MODEL=gemini-2.5-pro

# Pure HTTP service binding (hooks use unix socket; set tcp to expose service over TCP)
AXO_LINK_SERVICE_HTTP_BIND=unix
AXO_LINK_SERVICE_UNIX_SOCKET=/run/omni-root/mcp.sock
# AXO_LINK_SERVICE_ADDR=:18061      # optional: TCP bind for pure HTTP service

# MCP streamable HTTP server (agent clients connect here)
# AXO_LINK_MCP_ADDR=:18062          # default — uncomment only to override

# Tunnel MCP auth headers (passed to agent configs)
AXO_LINK_MCP_AUTH_TOKEN=
AXO_LINK_MCP_SENDER_ID=
AXO_LINK_MCP_SENDER_TYPE=
AXO_LINK_MCP_AGENT_WORKSPACE=

# Build / runtime options
DEBUG=0
VERSION=dev

# Suppress claude first-run security notice, telemetry, and auto-updates
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_PACKAGE_MANAGER_AUTO_UPDATE=false
