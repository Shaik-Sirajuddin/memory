{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pre-tool-use.command.output",
  "type": "object",
  "definitions": {
    "PermissionDecision": {
      "enum": ["allow", "deny", "ask", "defer"],
      "type": "string"
    },
    "PreToolUseHookSpecificOutput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hookEventName": { "const": "PreToolUse", "type": "string" },
        "permissionDecision": { "$ref": "#/definitions/PermissionDecision", "default": null },
        "permissionDecisionReason": { "type": "string", "default": null },
        "updatedInput": { "type": "object", "default": null, "description": "Modified tool input to pass forward" },
        "additionalContext": { "type": "string", "default": null }
      },
      "required": ["hookEventName"]
    }
  },
  "properties": {
    "continue": { "type": "boolean", "default": true },
    "stopReason": { "type": "string", "default": null },
    "suppressOutput": { "type": "boolean", "default": false },
    "systemMessage": { "type": "string", "default": null },
    "decision": { "enum": ["block"], "type": "string", "default": null },
    "reason": { "type": "string", "default": null },
    "hookSpecificOutput": { "$ref": "#/definitions/PreToolUseHookSpecificOutput", "default": null }
  }
}
