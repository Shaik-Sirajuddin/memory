{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "before-tool.command.input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "transcript_path": { "type": "string" },
    "cwd": { "type": "string" },
    "hook_event_name": { "const": "BeforeTool", "type": "string" },
    "timestamp": { "type": "string", "description": "ISO 8601 execution time" },
    "tool_name": { "type": "string", "description": "Name of the tool being called" },
    "tool_input": { "type": "object", "description": "Model-generated arguments for the tool" },
    "mcp_context": {
      "type": "object",
      "description": "Optional MCP metadata",
      "nullable": true
    },
    "original_request_name": {
      "type": "string",
      "description": "Original tool name when tail calls are involved",
      "nullable": true
    }
  },
  "required": ["session_id", "transcript_path", "cwd", "hook_event_name", "timestamp", "tool_name", "tool_input"]
}
