{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "session-start.command.output",
  "type": "object",
  "properties": {
    "continue": { "type": "boolean", "default": true },
    "stopReason": { "type": "string", "default": null },
    "suppressOutput": { "type": "boolean", "default": false },
    "systemMessage": { "type": "string", "default": null },
    "hookSpecificOutput": {
      "type": "object",
      "properties": {
        "additionalContext": {
          "type": "string",
          "description": "Injected as the first turn of the session"
        }
      }
    }
  }
}
