{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "before-model.command.output",
  "type": "object",
  "properties": {
    "continue": { "type": "boolean", "default": true },
    "stopReason": { "type": "string", "default": null },
    "suppressOutput": { "type": "boolean", "default": false },
    "systemMessage": { "type": "string", "default": null },
    "hookSpecificOutput": {
      "type": "object",
      "properties": {
        "llm_request": {
          "type": "object",
          "description": "Overrides the LLM request (model, messages, config)"
        },
        "llm_response": {
          "type": "object",
          "description": "Synthetic response — if set, the actual LLM call is skipped"
        }
      }
    }
  }
}
