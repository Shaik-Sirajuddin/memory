# hook-operator environment variables
#
# Socket path for the hook-operator unix socket server.
# Priority: ServiceOptions.UnixPath (set by svc/setup) > this env var > default below.
HOOK_OPERATOR_SOCKET=/tmp/hook-operator.sock

# Absolute path to the omni CLI binary used in hook entries (e.g. /usr/local/bin/omni).
# Hook entries invoke: <binary> hook --event <name>
# Priority: BinaryPath option → this env var → exec.LookPath("omni").
HOOK_OPERATOR_BINARY=
