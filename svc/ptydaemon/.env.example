# ptydaemon environment variables

# Unix socket path for the raw PTY protocol (attach, exec, streaming).
# Default: /run/omni-<username>/omni-pty.sock
OMNI_PTY_SOCKET=/run/omni-user/omni-pty.sock

# SQLite database path for session persistence.
# Default: /var/lib/omni-<username>/ptydaemon.db
PTYDAEMON_DB=/var/lib/omni-user/ptydaemon.db

# Client transport selector. "http" uses PTYDAEMON_SOCKET; anything else uses OMNI_PTY_SOCKET.
# Default: unix
OMNI_PTY_CLIENT=unix

# Unix socket path used by the HTTP client (OMNI_PTY_CLIENT=http).
# Default: /tmp/ptydaemon.sock
PTYDAEMON_SOCKET=/tmp/ptydaemon.sock

# Enable debug-level logging. Any non-empty value activates it.
# Also activated when omni config Dev.Debug is true.
DEV=

# XDG config home override (used to locate omni/config.json for log level).
# Default: $HOME/.config
XDG_CONFIG_HOME=
