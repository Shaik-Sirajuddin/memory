# Tunnel MCP runtime environment examples.
# Choose one mode block for the process you are starting.

###############################################################################
# Example 1: stdio client only
###############################################################################
# Starts no server. Connects to an already-running local service process that
# exposes the MCP streamable HTTP endpoint.

AXO_LINK_MCP_TRANSPORT=stdio
AXO_LINK_MCP_AUTH_TOKEN=tunnel-mcp-dev-token
AXO_LINK_MCP_SENDER_ID=mcp-client
AXO_LINK_MCP_SENDER_TYPE=omni_agent
AXO_LINK_MCP_AGENT_WORKSPACE=/path/to/workspace

# Optional stdio endpoint overrides. Defaults should work for local installs.
# AXO_LINK_MCP_ADDR=http://127.0.0.1:18062
# AXO_LINK_MCP_HTTP_PATH=/mcp

###############################################################################
# Example 2: local service process
###############################################################################
# Starts MCP streamable HTTP over TCP and pure HTTP service routes over unix.
# Uncomment this block when running the local service process instead of stdio.

# AXO_LINK_MCP_TRANSPORT=streamable_http
# AXO_LINK_MCP_ADDR=:18062
# AXO_LINK_MCP_HTTP_PATH=/mcp
# AXO_LINK_MCP_AUTH_TOKEN=tunnel-mcp-dev-token
# AXO_LINK_MCP_DB_PATH=.temp/mcp/messages.db
# AXO_LINK_MCP_DELIVERY_MODE=async

# AXO_LINK_SERVICE_HTTP_BIND=unix
# AXO_LINK_SERVICE_UNIX_SOCKET=/run/omni-${USER}/service.sock
# AXO_LINK_SERVICE_ADDR=:18061

###############################################################################
# Compatibility
###############################################################################
# AXO_LINK_MCP_TRANSPORT supports only streamable_http or stdio in the target
# split. http_unix belongs to AXO_LINK_SERVICE_HTTP_BIND, not MCP transport.
# Stdio is bridge-only and expects the local service process to already exist.
